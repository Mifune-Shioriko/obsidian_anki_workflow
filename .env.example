# ==========================================
# 必填配置 (Required)
# ==========================================
GOOGLE_API_KEY=
VAULT_DIR=

# ==========================================
# 混合模型路由配置 (LLM Routing Configuration)
# ==========================================
# 默认大模型服务商 ("gemini" 或 "qwen")
DEFAULT_LLM_PROVIDER=qwen

# 各个 Agent 的模型服务商配置
AGENT_DEFAULT_PROVIDER=qwen
AGENT_EXPLAIN_PROVIDER=qwen
AGENT_DIG_PROVIDER=qwen
AGENT_ADD_PROVIDER=qwen
AGENT_NEW_PROVIDER=qwen
AGENT_REVISE_PROVIDER=qwen

# 以下建议保持绑定 gemini 以确保文档及多模态解析能力
AGENT_FILE_PROVIDER=gemini
AGENT_PUBMED_PROVIDER=gemini
SCRIPT_SOLVE_HW_PROVIDER=gemini

# 阿里云通义千问配置
QWEN_API_KEY=
# Qwen 具体的模型名称 (如 qwen3.7-plus, qwen3.7-max)
QWEN_MODEL_NAME=qwen3.7-plus

# ==========================================
# 可选配置 (Optional)
# ==========================================
ANKI_URL=http://127.0.0.1:8765
ANKI_DECK_NAME=Obsidian
ANKI_NOTE_TYPE=Obsidian
OBSIDIAN_VAULT_NAME=my_obsidian_notes
