setwd("~/scripts/Obsidian/Anki")
# 如果没有安装这些包，请取消下面这行的注释进行安装
# install.packages(c("tidyverse", "patchwork"))
library(tidyverse)
library(patchwork)
# 1. 读取刚刚导出的数据
df <- read_csv("anki_rev_data.csv")
# 2. 划定激进的“收益悬崖”阈值
# 假设我们想舍弃表现最差的 5% 卡片，以及间隔达到前 10% 的卡片
thresholds <- list(
lapses_95 = quantile(df$lapses, 0.95),  # 95%的卡片遗忘次数都在这个数值以下
ease_05   = quantile(df$ease, 0.05),    # 底部5%的易度地狱
ivl_90    = quantile(df$interval, 0.90) # 头部10%的超长间隔
)
cat("=== 建议的激进清理阈值 ===\n")
cat("水蛭阈值 (Lapses >):", thresholds$lapses_95, "\n")
cat("易度阈值 (Ease <):", thresholds$ease_05, "\n")
cat("内化阈值 (Interval >):", thresholds$ivl_90, "\n")
cat("==========================\n")
# 3. 绘制数据分布与阈值红线
# 图 A: Lapses (遗忘次数) 分布图
p_lapses <- ggplot(df, aes(x = lapses)) +
geom_histogram(binwidth = 1, fill = "#4A90E2", color = "white") +
geom_vline(xintercept = thresholds$lapses_95, color = "#E74C3C", linetype = "dashed", size = 1) +
labs(title = "遗忘次数 (Lapses) 分布",
subtitle = "红线右侧为消耗精力的 '水蛭' 卡片",
x = "遗忘次数", y = "卡片数量") +
theme_minimal()
# 图 B: Ease (易度) 分布图
p_ease <- ggplot(df, aes(x = ease)) +
geom_histogram(binwidth = 10, fill = "#50E3C2", color = "white") +
geom_vline(xintercept = thresholds$ease_05, color = "#E74C3C", linetype = "dashed", size = 1) +
labs(title = "易度 (Ease) 分布",
subtitle = "红线左侧为难以翻身的 '易度地狱'",
x = "易度 (%)", y = "卡片数量") +
theme_minimal()
# 图 C: Interval (复习间隔) 分布图
# 因为长间隔可能非常长（几年），我们加上 xlim 截断一下极值以便观察主体
p_ivl <- ggplot(df, aes(x = interval)) +
geom_histogram(binwidth = 10, fill = "#F5A623", color = "white") +
geom_vline(xintercept = thresholds$ivl_90, color = "#E74C3C", linetype = "dashed", size = 1) +
coord_cartesian(xlim = c(0, quantile(df$interval, 0.99))) +
labs(title = "复习间隔 (Interval) 分布",
subtitle = "红线右侧为已经 '长久内化' 的卡片",
x = "间隔 (天)", y = "卡片数量") +
theme_minimal()
# 4. 拼图并展示
(p_lapses | p_ease) / p_ivl
